# Database PostgreSQL (Neon Remote)
PGHOST=ep-dawn-shadow-ahog1w8a-pooler.c-3.us-east-1.aws.neon.tech
PGDATABASE=neondb
PGUSER=neondb_owner
PGPASSWORD=your_neon_password
PGSSLMODE=require
PGCHANNELBINDING=require

# Redis (Docker)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_password
REDIS_DB=0

# Node.js
NODE_ENV=development
PORT=3000

# JWT Secret
JWT_SECRET=your_jwt_secret_key

# Session Secret (para segurança de sessão com Redis)
SESSION_SECRET=your_session_secret_key

# CORS Configuration
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://seu-dominio.com
FRONTEND_URL=http://localhost:5173

# Google Gemini API Keys
GEMINI_API_KEY=your_gemini_key
GEMINI_API_KEY2=your_gemini_key2
GEMINI_API_KEY3=your_gemini_key3
GEMINI_API_KEY4=your_gemini_key4
GEMINI_API_KEY5=your_gemini_key5

# Services
PERSON_SERVICE_URL=http://localhost:3000

# Google Cloud (opcional)
GOOGLE_APPLICATION_CREDENTIALS=path/to/credentials.json
